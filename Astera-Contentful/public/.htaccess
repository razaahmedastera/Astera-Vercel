# Next.js Static Export Routing
# Handles direct URL access by checking for .html files first
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # IMPORTANT: Allow _next static files to be served directly (must be first)
  # This ensures Next.js chunks, CSS, and other static assets load correctly
  # Skip all rewrite rules for _next files - let Apache serve them directly
  RewriteCond %{REQUEST_URI} ^/_next/
  RewriteRule ^(.*)$ - [L]
  
  # Remove trailing slash (except for root)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]
  
  # Handle directory requests - redirect /blog/ to /blog.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} ^/(blog|product)/
  RewriteRule ^(.*)/$ /$1.html [R=301,L]
  
  # If URL doesn't have extension and .html file exists, serve it
  # Example: /product -> /product.html
  # BUT: Skip /blog/* routes to allow client-side routing for real-time blog posts
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/blog/
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
  
  # Route ALL /blog/* URLs to index.html for client-side routing
  # This enables real-time blog posts - new posts published in Contentful
  # will be accessible immediately without rebuilding
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^/blog/[^/]+$
  RewriteRule ^(.*)$ /index.html [L]
  
  # If no .html file exists, rewrite to index.html for client-side routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|json|map|html)$ [NC]
  RewriteCond %{REQUEST_URI} !^/_next/
  RewriteCond %{REQUEST_URI} !^/index\.html$
  RewriteCond %{REQUEST_URI} !^/$
  RewriteCond %{REQUEST_URI} !^/blog/
  RewriteRule ^(.*)$ /index.html [L]
</IfModule>

# Allow access to _next folder and its files (fixes 403 Forbidden error)
<DirectoryMatch "^.*/_next/">
  Options -Indexes +FollowSymLinks
  AllowOverride None
  Require all granted
</DirectoryMatch>

# Explicitly allow _next static files
<FilesMatch "^/_next/.*">
  Require all granted
</FilesMatch>

# Enable Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Cache-Control Headers
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=2592000, public"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
