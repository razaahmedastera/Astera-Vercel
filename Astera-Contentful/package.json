{
  "name": "asteraweb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:clean": "node scripts/clean-cache.js && next dev",
    "clean": "node scripts/clean-cache.js",
    "clean:next": "Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; Write-Host 'Cleaned .next directory'",
    "build": "next build",
    "build:static": "cross-env STATIC_EXPORT=true NODE_ENV=production next build && node scripts/copy-htaccess.js",
    "start": "next start",
    "lint": "next lint",
    "export": "next build"
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "^15.22.11",
    "@contentful/rich-text-types": "^16.8.5",
    "contentful": "^11.10.1",
    "lottie-react": "^2.4.1",
    "next": "^15.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.97.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2"
  }
}
